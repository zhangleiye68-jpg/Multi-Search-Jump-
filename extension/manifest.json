{
  "manifest_version": 3,
  "name": "Multi Search Jump",
  "description": "Open one query across selected search platforms.",
  "version": "0.2.0",
  "action": {
    "default_title": "Multi Search Jump",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "side_panel": {
    "default_path": "side-panel/panel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*"
      ],
      "css": [
        "src/tiktokCaptionOverlay.css"
      ],
      "js": [
        "src/tiktokCaptionCore.js",
        "src/tiktokCaptionContent.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.tiktok.com/*"
      ],
      "js": [
        "src/tiktokCaptionBridge.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "commands": {
    "search-selected-text": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Search selected text with Multi Search Jump"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "sidePanel",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/",
    "https://*.tiktok.com/*",
    "https://*.tiktokcdn.com/*",
    "https://*.byteoversea.com/*",
    "https://*.byteimg.com/*",
    "https://*.ibyteimg.com/*"
  ]
}
