{
  "manifest_version": 3,
  "name": "Multi Search Jump",
  "description": "Open one query across selected search platforms.",
  "version": "0.2.0",
  "action": {
    "default_title": "Multi Search Jump",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
