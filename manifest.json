{
  "manifest_version": 3,
  "name": "Multi Search Jump",
  "description": "Open one query across Google, X, Facebook, and TikTok search results.",
  "version": "0.1.0",
  "action": {
    "default_title": "Multi Search Jump",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs"
  ]
}
