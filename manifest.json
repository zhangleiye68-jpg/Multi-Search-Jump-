{
  "manifest_version": 3,
  "name": "Multi Search Jump",
  "description": "Open one query across selected search platforms.",
  "version": "0.2.0",
  "action": {
    "default_title": "Multi Search Jump",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "commands": {
    "search-selected-text": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Search selected text with Multi Search Jump"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "sidePanel",
    "contextMenus",
    "activeTab",
    "scripting"
  ]
}
